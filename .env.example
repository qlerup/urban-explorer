# Koer scripts/generate-secrets.ps1 (Windows) eller scripts/generate-secrets.sh (Linux/Mac)
DB_PASSWORD=skift_mig_til_noget_staerkt
JWT_SECRET=skal_vaere_mindst_64_bytes_base64_koer_generate_secrets
ENCRYPTION_KEY=skal_vaere_praecis_32_bytes_base64_koer_generate_secrets

# MapTiler API key - opret gratis konto paa https://cloud.maptiler.com/ og indsaet din key her
MAPTILER_KEY=indsaet_din_maptiler_key

# Mappe paa Docker-hosten til uploadede billeder. Kan vaere et monteret NFS-share.
UPLOADS_HOST_DIR=./data/uploads
